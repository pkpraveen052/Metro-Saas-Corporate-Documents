<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <template id="assets_backend" inherit_id="web.assets_backend">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="/metro_corporate_docs/static/src/css/dashboard.css"/>
                <script type="text/javascript" src="/metro_corporate_docs/static/src/js/dashboard.js"></script>
            </xpath>
        </template>

        <template id="MetroCorporateDocsDashboard">
            <div class="metro-dashboard o_form_view">
                <div class="metro-dashboard__header">
                    <div>
                        <h1>Corporate Documents Dashboard</h1>
                        <p>Quick access to the submitted corporate forms</p>
                    </div>
                    <div class="o_searchview_container">
                        <input type="text" class="o_searchview_input" placeholder="Search..." />
                    </div>
                </div>

                <div class="metro-dashboard__cards">
                    <div class="metro-dashboard__card">
                        <h3>Address Change</h3>
                        <div class="count"><t t-esc="dashboard_data.address_change_count or 0"/></div>
                        <button type="button" class="btn btn-primary o_dashboard_card_open" data-action="metro_corporate_docs.corporate_address_change_action">
                            Open Address Change
                        </button>
                    </div>
                    <div class="metro-dashboard__card">
                        <h3>Appointment Secretary</h3>
                        <div class="count"><t t-esc="dashboard_data.appointment_secretary_count or 0"/></div>
                        <button type="button" class="btn btn-primary o_dashboard_card_open" data-action="metro_corporate_docs.corporate_appointment_secretary_action">
                            Open Appointment Secretary
                        </button>
                    </div>
                    <div class="metro-dashboard__card">
                        <h3>Resignation Secretary</h3>
                        <div class="count"><t t-esc="dashboard_data.resignation_secretary_count or 0"/></div>
                        <button type="button" class="btn btn-primary o_dashboard_card_open" data-action="metro_corporate_docs.corporate_resignation_secretary_action">
                            Open Resignation Secretary
                        </button>
                    </div>
                </div>

                <div class="metro-dashboard__links">
                    <button type="button" class="btn btn-secondary o_dashboard_link" data-action="metro_corporate_docs.corporate_address_change_action">View all Address Changes</button>
                    <button type="button" class="btn btn-secondary o_dashboard_link" data-action="metro_corporate_docs.corporate_appointment_secretary_action">View all Appointment Secretary</button>
                    <button type="button" class="btn btn-secondary o_dashboard_link" data-action="metro_corporate_docs.corporate_resignation_secretary_action">View all Resignation Secretary</button>
                </div>
            </div>
        </template>



        <record id="action_metro_corporate_docs_dashboard_fallback" model="ir.actions.act_window">
            <field name="name">Corporate Documents Dashboard Fallback</field>
            <field name="res_model">metro.corporate.docs.dashboard</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
        </record>


        <menuitem id="menu_corporate_documents_dashboard_fallback"
                  name="Dashboard"
                  parent="metro_corporate_docs.menu_corporate_documents_root"
                  action="action_metro_corporate_docs_dashboard_fallback"
                  sequence="1"/>

    </data>
</odoo>
