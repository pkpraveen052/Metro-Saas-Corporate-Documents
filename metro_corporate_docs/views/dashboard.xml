<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <template id="assets_backend" inherit_id="web.assets_backend">
            <xpath expr="." position="inside">
                <link rel="stylesheet" href="/metro_corporate_docs/static/src/css/dashboard.css"/>
                <script type="text/javascript" src="/metro_corporate_docs/static/src/js/dashboard.js"></script>
            </xpath>
        </template>

        <template id="MetroCorporateDocsDashboard">
            <div class="metro-dashboard">
                <div class="metro-dashboard__hero">
                    <div>
                        <h1>Corporate Documents Dashboard</h1>
                        <p>Open forms quickly and monitor records with one click.</p>
                    </div>
                    <div class="metro-dashboard__badge">
                        <i class="fa fa-line-chart"/>
                        <span>Live overview</span>
                    </div>
                </div>

                <div class="metro-dashboard__cards">
                    <div class="metro-dashboard__card metro-dashboard__card--address">
                        <div class="metro-dashboard__icon"><i class="fa fa-map-marker"/></div>
                        <h3>Address Change</h3>
                        <div class="count"><t t-esc="dashboard_data.address_change_count or 0"/></div>
                        <button type="button" class="btn btn-light o_dashboard_open_action" data-model="corporate.address.change" data-name="Corporate Address Change">
                            View Records
                        </button>
                    </div>

                    <div class="metro-dashboard__card metro-dashboard__card--appointment">
                        <div class="metro-dashboard__icon"><i class="fa fa-user-plus"/></div>
                        <h3>Appointment Secretary</h3>
                        <div class="count"><t t-esc="dashboard_data.appointment_secretary_count or 0"/></div>
                        <button type="button" class="btn btn-light o_dashboard_open_action" data-model="corporate.appointment.secretary" data-name="Corporate Appointment Secretary">
                            View Records
                        </button>
                    </div>

                    <div class="metro-dashboard__card metro-dashboard__card--resignation">
                        <div class="metro-dashboard__icon"><i class="fa fa-user-times"/></div>
                        <h3>Resignation Secretary</h3>
                        <div class="count"><t t-esc="dashboard_data.resignation_secretary_count or 0"/></div>
                        <button type="button" class="btn btn-light o_dashboard_open_action" data-model="corporate.resignation.secretary" data-name="Corporate Resignation Secretary">
                            View Records
                        </button>
                    </div>
                </div>
            </div>
        </template>

        <record id="action_metro_corporate_docs_dashboard" model="ir.actions.client">
            <field name="name">Corporate Documents Dashboard</field>
            <field name="tag">metro_corporate_docs.dashboard</field>
            <field name="target">current</field>
        </record>

        <record id="action_metro_corporate_docs_dashboard_fallback" model="ir.actions.act_window">
            <field name="name">Corporate Documents Dashboard (Legacy)</field>
            <field name="res_model">corporate.address.change</field>
            <field name="view_mode">tree,form</field>
            <field name="target">current</field>
        </record>

        <record id="menu_corporate_documents_dashboard_fallback" model="ir.ui.menu">
            <field name="name">Dashboard</field>
            <field name="parent_id" ref="metro_corporate_docs.menu_corporate_documents_root"/>
            <field name="action" eval="'ir.actions.act_window,%d' % ref('metro_corporate_docs.action_metro_corporate_docs_dashboard_fallback')"/>
            <field name="sequence">1</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
