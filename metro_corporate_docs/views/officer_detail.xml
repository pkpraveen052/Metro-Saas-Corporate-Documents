<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--    account move    -->
        <record id="officer_detail_form" model="ir.ui.view">
            <field name="name">officer.detail.form</field>
            <field name="model">officer.detail</field>
            <field name="arch" type="xml">
                <form string="Officer Detail">
                    <sheet>
                        <div class="oe_title">
                            <span class="o_form_label">Name</span>
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <label for="street" string="Address"/>
                                <div class="o_address_format">
                                    <field name="street" placeholder="Street..." class="o_address_street"/>
                                    <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                    <field name="city" placeholder="City" class="o_address_city"/>
                                    <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True, 'no_quick_create': True}" context="{'default_country_id': country_id}"/>
                                    <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                    <field name="country_id" placeholder="Country" class="o_address_country" options='{"no_open": True, "no_create": True}'/>
                                </div>
                            </group>
                            <group>
                                <field name="identification_number"/>
                                <field name="email"/>
                                <field name="nationality"/>
                                <field name="position"/>
                                <field name="appointment_date"/>
                                <field name="company_id" invisible="1"/>
                                <field name="officer_address" invisible="1"/>
                                <field name="total_number_share"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="officer_detail_tree" model="ir.ui.view">
        <field name="name">officer.detail.tree</field>
        <field name="model">officer.detail</field>
        <field name="arch" type="xml">
            <tree string="Officer Detail">
                <field name="name"/>
                <field name="identification_number"/>
                <field name="email"/>
                <field name="nationality"/>
                <field name="position"/>
                <field name="appointment_date"/>
                <field name="company_id" invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="action_officer_detail" model="ir.actions.act_window">
        <field name="name">Officer</field>
        <field name="res_model">officer.detail</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Officer Details
            </p>
        </field>
    </record>
    </data>
</odoo>
